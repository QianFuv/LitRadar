{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "next dev --port 8000",
    "build": "next build",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:api": "cargo run --manifest-path ../Cargo.toml --quiet --bin litradar -- openapi --output lib/generated/openapi.json && openapi-typescript lib/generated/openapi.json -o lib/generated/api-schema.tsx --alphabetize && prettier --write lib/generated/openapi.json lib/generated/api-schema.tsx",
    "generate:api:check": "node scripts/check-generated-api.mjs",
    "test": "vitest run --config vitest.config.tsx",
    "test:coverage": "vitest run --config vitest.config.tsx --coverage",
    "test:watch": "vitest --config vitest.config.tsx",
    "test:e2e": "playwright test --config playwright.config.tsx"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-query": "^5.90.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-intersection-observer": "^10.0.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
